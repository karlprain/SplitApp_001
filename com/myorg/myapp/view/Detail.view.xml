<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    controllerName="com.myorg.myapp.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Page title="Product Details" showNavButton="true" navButtonPress="onNavBack" class="sapUiResponsiveContentPadding">
        <content>
            <f:SimpleForm editable="false" layout="ResponsiveGridLayout">
                <f:content>
                    <Label text="Product ID" />
                    <Text text="{/selectedProduct/productId}" />
                    <Label text="Product Name" />
                    <Text text="{/selectedProduct/productName}" />
                    <Label text="Category" />
                    <Text text="{/selectedProduct/category}" />
                    <Label text="Description" />
                    <Text text="{/selectedProduct/description}" />
                    <Label text="Price (USD)" />
                    <Text text="{/selectedProduct/price}" />
                    <Label text="In Stock" />
                    <Text text="{/selectedProduct/inStock}" />
                </f:content>
            </f:SimpleForm>
        </content>
    </Page>
</mvc:View>
