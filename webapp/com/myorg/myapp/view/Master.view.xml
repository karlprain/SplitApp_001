<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    controllerName="com.myorg.myapp.controller.Master"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <App id="app">
        <pages>
            <Page title="Products" class="sapUiResponsiveContentPadding">
                <headerContent>
                    <Button icon="sap-icon://refresh" press="onRefreshList" />
                </headerContent>
                <content>
                    <List id="masterList" items="{/products}" mode="SingleSelectMaster" selectionChange="onSelectionChange">
                        <StandardListItem title="{productName}" description="{category}" type="Navigation" press="onNavToDetail">
                            <customData>
                                <core:CustomData key="productId" value="{productId}" />
                            </customData>
                        </StandardListItem>
                    </List>
                </content>
            </Page>
        </pages>
    </App>
</mvc:View>
